# =============================================================================
# Supabase Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api
# =============================================================================

# Your Supabase project URL
# Found at: Project Settings > API > Project URL
# Format: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anonymous/public key
# Found at: Project Settings > API > Project API keys > anon/public
# This key is safe to use in browser code
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# Optional: Additional Supabase Configuration
# =============================================================================

# Your Supabase service role key (KEEP SECRET - server-side only!)
# Found at: Project Settings > API > Project API keys > service_role
# WARNING: Never expose this in client-side code or commit to version control
# SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# NVIDIA NIM AI
# =============================================================================

# API key for the NVIDIA NIM inference API.
# Get yours at: https://build.nvidia.com
NVIDIA_API_KEY=

# =============================================================================
# Google Cloud Text-to-Speech
# =============================================================================

# Path to the Google Cloud service account JSON file (local dev only — not supported on Vercel).
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-credentials.json

# Full Google Cloud service account JSON as a string (required on Vercel / any serverless host).
# Copy the entire contents of your service-account JSON file as the value.
# In the Vercel dashboard: Settings > Environment Variables > paste the raw JSON as the value.
GOOGLE_APPLICATION_CREDENTIALS=
