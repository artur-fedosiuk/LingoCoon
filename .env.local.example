# =============================================================================
# Supabase Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api
# =============================================================================

# Your Supabase project URL
# Found at: Project Settings > API > Project URL
# Format: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anonymous/public key
# Found at: Project Settings > API > Project API keys > anon/public
# This key is safe to use in browser code
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public URL of this application.
# Use http://localhost:3000 during local development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Optional: Additional Supabase Configuration
# =============================================================================

# Your Supabase service role key (KEEP SECRET - server-side only!)
# Found at: Project Settings > API > Project API keys > service_role
# WARNING: Never expose this in client-side code or commit to version control
# SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# ElevenLabs Text-to-Speech (free tier)
# =============================================================================
#
# Create a free ElevenLabs account and an API key:
# https://elevenlabs.io/app/developers/api-keys
#
# The free API allowance includes 10,000 credits per refresh period.
# Eleven v3 currently uses one credit per text character for text-to-speech.
# Keep pay-as-you-go disabled to guarantee that the app never incurs TTS charges.
# When the free allowance is exhausted, audio generation stops until it resets.
#
# ElevenLabs does not expose Voice Library voices through the API on the free
# tier. The app falls back to verified free female and male Default voices.
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID_FEMALE=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_VOICE_ID_MALE=pNInz6obpgDQGcFmaJgB
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# =============================================================================
# Groq AI chat and Speech-to-Text (free tier)
# =============================================================================
#
# Create a free Groq API key:
# https://console.groq.com/keys
#
# The app uses Groq for low-latency chat, structured dictionary responses, and
# Whisper Large V3 multilingual push-to-talk input.
# Keep this key server-side only. Never prefix it with NEXT_PUBLIC_.
GROQ_API_KEY=
# GROQ_STT_MODEL_ID=whisper-large-v3
# GROQ_CHAT_MODEL_ID=llama-3.1-8b-instant
# GROQ_STRUCTURED_MODEL_ID=openai/gpt-oss-120b
