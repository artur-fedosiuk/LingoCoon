# =============================================================================
# Supabase Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api
# =============================================================================

# Your Supabase project URL
# Found at: Project Settings > API > Project URL
# Format: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anonymous/public key
# Found at: Project Settings > API > Project API keys > anon/public
# This key is safe to use in browser code
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# Optional: Additional Supabase Configuration
# =============================================================================

# Your Supabase service role key (KEEP SECRET - server-side only!)
# Found at: Project Settings > API > Project API keys > service_role
# WARNING: Never expose this in client-side code or commit to version control
# SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# NVIDIA NIM AI
# =============================================================================

# API key for the NVIDIA NIM inference API.
# Get yours at: https://build.nvidia.com
NVIDIA_API_KEY=

# =============================================================================
# Google Cloud Text-to-Speech
# =============================================================================
#
# Instead of pointing to a JSON file on disk, we embed the entire service-account
# JSON as a single environment variable. This is safer (no file path = no path
# traversal risk) and works on any deployment platform (Vercel, Railway, Render).
#
# HOW TO SET THIS UP:
#
# 1. Go to Google Cloud Console → IAM → Service Accounts → your account → Keys → Add Key → JSON
# 2. Download the .json file (keep it out of version control!)
# 3. Open the file and copy its entire contents.
# 4. Convert it to a single-line string:
#    - On Mac/Linux: cat your-key.json | tr -d '\n' | pbcopy
#    - Or use any JSON minifier online.
# 5. Paste it as the value below (the entire JSON object, no quotes needed).
#
# EXAMPLE (replace all values with yours):
#   GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"my-project","private_key_id":"abc123","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n","client_email":"my-sa@my-project.iam.gserviceaccount.com","client_id":"123","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/my-sa%40my-project.iam.gserviceaccount.com"}
#
GOOGLE_SERVICE_ACCOUNT_JSON=
