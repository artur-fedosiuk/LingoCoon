# FIREBASE CONFIGURATION (Required)
# Ottieni questi valori dalla console Firebase -> Project Settings
VITE_FIREBASE_API_KEY=inserisci_qui_api_key
VITE_FIREBASE_AUTH_DOMAIN=inserisci_qui_auth_domain
VITE_FIREBASE_PROJECT_ID=inserisci_qui_project_id
VITE_FIREBASE_STORAGE_BUCKET=inserisci_qui_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=inserisci_qui_sender_id
VITE_FIREBASE_APP_ID=inserisci_qui_app_id

# AI SERVICES (Optional but recommended)
# Google Cloud Console -> APIs & Services -> Credentials
VITE_GOOGLE_TTS_API_KEY=inserisci_qui_google_tts_key
# Hugging Face -> Settings -> Access Tokens
VITE_HUGGING_FACE_KEY=hf_inserisci_qui_tuo_token